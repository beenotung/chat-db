{
  "name": "chat-db",
  "version": "0.0.0",
  "type": "commonjs",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ts-node src/cli.ts",
    "test": "tsc --noEmit",
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc -p . && rimraf dist/tsconfig.tsbuildinfo dist/*.test.d.ts dist/*.test.js dist/*.spec.d.ts dist/*.spec.js",
    "tsc": "tsc -p .",
    "dev": "tsc -p . --watch",
    "db:ui": "erd-ui erd.txt",
    "db:setup": "npm run db:migrate",
    "db:dev": "run-s db:migrate db:plan db:update",
    "db:migrate": "knex migrate:latest",
    "db:plan": "auto-migrate db.sqlite3 < erd.txt",
    "db:rename": "auto-migrate --rename db.sqlite3 < erd.txt",
    "db:update": "run-s db:migrate db:gen-proxy",
    "db:gen-proxy": "erd-to-proxy < erd.txt > src/proxy.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/integer": "^4.0.3",
    "@types/node": "^24.13.2",
    "gen-env": "^1.0.1",
    "npm-run-all": "^4.1.5",
    "quick-erd": "^4.34.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@beenotung/tslib": "^24.26.0",
    "better-sqlite3": "^12.6.2",
    "better-sqlite3-proxy": "^2.10.1",
    "better-sqlite3-schema": "^3.1.7",
    "knex": "^3.1.0",
    "populate-env": "^2.6.1",
    "puppeteer": "24.38.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer",
      "better-sqlite3"
    ]
  }
}
